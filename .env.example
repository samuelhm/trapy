# OpenAI API Configuration
OPENAI_API_KEY=sk-...

# Realtime API Model
REALTIME_MODEL=gpt-realtime
REALTIME_WS_URL=wss://api.openai.com/v1/realtime

# Translation Mode
# Options: keyboard_hold, mouse_hold, simultaneous, turn
# - keyboard_hold: Hold F8 (ES→EN) or F9 (EN→ES), release to translate
# - mouse_hold: Left/middle click and drag
# - simultaneous: Both flows active continuously
# - turn: Manual control
TRANSLATION_MODE=keyboard_hold

# PTT Key Configuration (keyboard_hold mode)
OUTGOING_PTT_KEYS=f8  # Spanish to English translation
INCOMING_PTT_KEYS=f9  # English to Spanish translation

# Virtual Audio Device Names (PulseAudio/PipeWire)
MIC_VIRTUAL_SINK=Mic_Virtual
MIC_VIRTUAL_SOURCE=Mic_Virtual_Input
ALTAVOZ_VIRTUAL_SINK=Altavoz_Virtual

# Physical Audio Device IDs (optional)
# Leave empty to auto-detect. Get IDs with:
#   python -c "import sounddevice as sd; print(sd.query_devices())"
PHYSICAL_MIC_INPUT_DEVICE=
PHYSICAL_SPEAKER_OUTPUT_DEVICE=

# Audio Stream Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_MS=10
